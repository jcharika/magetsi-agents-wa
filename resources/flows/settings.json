{
  "version": "7.3",
  "data_api_version": "3.0",
  "screens": [
    {
      "id": "SETTINGS_SCREEN",
      "terminal": true,
      "title": "Agent Settings",
      "data": {
        "ecocash_number": {
          "type": "string",
          "__example__": "0771234567"
        },
        "amount_1": {
          "type": "string",
          "__example__": "100"
        },
        "amount_2": {
          "type": "string",
          "__example__": "200"
        },
        "amount_3": {
          "type": "string",
          "__example__": "300"
        },
        "amount_4": {
          "type": "string",
          "__example__": "500"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Your Preferences"
          },
          {
            "type": "TextBody",
            "text": "Update your default EcoCash number and quick amounts for ZESA purchases."
          },
          {
            "type": "TextSubheading",
            "text": "Default EcoCash Number"
          },
          {
            "type": "TextInput",
            "name": "ecocash_number",
            "label": "EcoCash Number",
            "input-type": "phone",
            "required": true,
            "helper-text": "This number will be pre-filled on purchases"
          },
          {
            "type": "TextSubheading",
            "text": "⚡ ZESA Quick Amounts (ZWG)"
          },
          {
            "type": "TextBody",
            "text": "Set 4 amounts shown as quick-select buttons during purchases."
          },
          {
            "type": "TextInput",
            "name": "amount_1",
            "label": "Slot 1",
            "input-type": "number",
            "required": true,
            "helper-text": "Min ZWG 100"
          },
          {
            "type": "TextInput",
            "name": "amount_2",
            "label": "Slot 2",
            "input-type": "number",
            "required": true,
            "helper-text": "Min ZWG 100"
          },
          {
            "type": "TextInput",
            "name": "amount_3",
            "label": "Slot 3",
            "input-type": "number",
            "required": true,
            "helper-text": "Min ZWG 100"
          },
          {
            "type": "TextInput",
            "name": "amount_4",
            "label": "Slot 4",
            "input-type": "number",
            "required": true,
            "helper-text": "Min ZWG 100"
          },
          {
            "type": "Footer",
            "label": "Save Settings",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "ecocash_number": "${form.ecocash_number}",
                "amount_1": "${form.amount_1}",
                "amount_2": "${form.amount_2}",
                "amount_3": "${form.amount_3}",
                "amount_4": "${form.amount_4}"
              }
            }
          }
        ]
      }
    }
  ]
}
