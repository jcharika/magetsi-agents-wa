{
    "version": "7.3",
    "data_api_version": "3.0",
    "routing_model": {
        "BUY_ZESA_SCREEN": []
    },
    "screens": [
        {
            "id": "BUY_ZESA_SCREEN",
            "terminal": true,
            "title": "Buy ZESA Token",
            "data": {
                "meter_valid": {
                    "type": "boolean",
                    "__example__": false
                },
                "show_custom_amount": {
                    "type": "boolean",
                    "__example__": false
                },
                "customer_name": {
                    "type": "string",
                    "__example__": "Jack Daniels"
                },
                "customer_address": {
                    "type": "string",
                    "__example__": "123 Mbudzi Street"
                },
                "meter_currency": {
                    "type": "string",
                    "__example__": "ZWG"
                },
                "currency": {
                    "type": "string",
                    "__example__": "ZWG"
                },
                "min_amount": {
                    "type": "number",
                    "__example__": 100
                },
                "ecocash_number": {
                    "type": "string",
                    "__example__": "0771234567"
                }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "Image",
                        "src": "",
                        "width": 100,
                        "height": 100
                    },
                    {
                        "type": "TextInput",
                        "name": "meter_number",
                        "label": "Meter Number",
                        "input-type": "number",
                        "label-variant": "large",
                        "required": true,
                        "helper-text": "Enter your 11-digit ZESA meter number"
                    },
                    {
                        "type": "If",
                        "condition": "${data.customer_name} != ''",
                        "then": [
                            {
                                "type": "TextSubheading",
                                "text": "${data.customer_name}"
                            },
                            {
                                "type": "TextBody",
                                "text": "${data.customer_address}"
                            },
                            {
                                "type": "TextCaption",
                                "font-weight": "bold",
                                "text": "${data.meter_currency}"
                            }
                        ]
                    },

                    {
                        "type": "EmbeddedLink",
                        "text": "Verify meter number details",
                        "on-click-action": {
                            "name": "data_exchange",
                            "payload": {
                                "trigger": "verify_meter_number",
                                "meter_number": "${form.meter_number}"
                            }
                        }
                    },
                    {
                        "type": "If",
                        "condition": "${data.meter_valid}",
                        "then": [
                            {
                                "type": "TextInput",
                                "name": "amount",
                                "label": "Amount (ZWG)",
                                "label-variant": "large",
                                "input-type": "number",
                                "required": true
                            },
                            {
                                "type": "TextInput",
                                "name": "ecocash_number",
                                "label": "EcoCash Number",
                                "label-variant": "large",
                                "input-type": "phone",
                                "required": true,
                                "init-value": "${data.ecocash_number}",
                                "helper-text": "Payment will be deducted from this number"
                            },
                            {
                                "type": "TextInput",
                                "name": "recipient_phone",
                                "label": "Send Token To",
                                "label-variant": "large",
                                "input-type": "phone",
                                "required": false,
                                "helper-text": "Customer phone for SMS token delivery"
                            },

                            {
                                "type": "Footer",
                                "label": "⚡ Submit Transaction",
                                "enabled": "${data.meter_valid}",
                                "on-click-action": {
                                    "name": "data_exchange",
                                    "payload": {
                                        "trigger": "buy_zesa",
                                        "meter_number": "${form.meter_number}",
                                        "amount": "${form.amount}",
                                        "ecocash_number": "${form.ecocash_number}",
                                        "recipient_phone": "${form.recipient_phone}"
                                    }
                                }
                            }
                        ],
                        "else": [
                            {
                                "type": "TextCaption",
                                "text": "⚠️ Please verify your meter number above before proceeding."
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
