{
    "version": "7.3",
    "data_api_version": "3.0",
    "routing_model": {
        "BUY_ZESA_SCREEN": []
    },
    "screens": [
        {
            "id": "BUY_ZESA_SCREEN",
            "terminal": true,
            "title": "Buy ZESA Tokens",
            "data": {
                "show_custom_amount": {
                    "type": "boolean",
                    "__example__": false
                },
                "quick_amounts": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "__example__": [100, 200, 300, 500]
                },
                "currency": {
                    "type": "string",
                    "__example__": "ZWG"
                },
                "min_amount": {
                    "type": "number",
                    "__example__": 100
                },
                "ecocash_number": {
                    "type": "string",
                    "__example__": "0771234567"
                }
            },
            "layout": {
                "type": "SingleColumnLayout",
                "children": [
                    {
                        "type": "TextBody",
                        "text": "Enter your meter and payment details below."
                    },
                    {
                        "type": "TextInput",
                        "name": "meter_number",
                        "label": "Meter Number",
                        "input-type": "number",
                        "label-variant": "large",
                        "required": true,
                        "helper-text": "Enter your 11-digit ZESA meter number"
                    },

                    {
                        "type": "TextInput",
                        "name": "amount",
                        "label": "Amount (ZWG)",
                        "label-variant": "large",
                        "input-type": "number",
                        "required": true
                    },
                    {
                        "type": "TextInput",
                        "name": "ecocash_number",
                        "label": "EcoCash Number",
                        "label-variant": "large",
                        "input-type": "phone",
                        "required": true,
                        "init-value": "${data.ecocash_number}",
                        "helper-text": "Payment will be deducted from this number"
                    },
                    {
                        "type": "TextInput",
                        "name": "recipient_phone",
                        "label": "Send Token To",
                        "label-variant": "large",
                        "input-type": "phone",
                        "required": false,
                        "helper-text": "Customer phone for SMS token delivery"
                    },
                    {
                        "type": "Footer",
                        "label": "⚡ Submit Transaction",
                        "on-click-action": {
                            "name": "data_exchange",
                            "payload": {
                                "meter_number": "${form.meter_number}",
                                "amount": "${form.amount}",
                                "ecocash_number": "${form.ecocash_number}",
                                "recipient_phone": "${form.recipient_phone}"
                            }
                        }
                    }
                ]
            }
        }
    ]
}
